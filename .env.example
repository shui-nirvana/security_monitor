# Blockchain Configuration
RPC_URL=https://eth-mainnet.public.blastapi.io
CHAIN_ID=1

# Monitoring Configuration
TARGET_TOKEN_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# AI Analysis Configuration (Optional)
ENABLE_AI_ANALYSIS=True
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# WDK Configuration (Guardian Mode)
# Leave empty to generate a random ephemeral wallet on startup
WDK_PRIVATE_KEY=
WDK_USE_TETHER_WDK=True
WDK_SEED_PHRASE=
WDK_ACCOUNT_INDEX=0
WDK_NODE_CMD=node
WDK_BRIDGE_SCRIPT=security_monitor/wdk_bridge/wdk_bridge.mjs
GUARDIAN_MAX_TRANSFER_AMOUNT=1000
GUARDIAN_SUPPORTED_ASSETS=USDT,USAT,XAUT
WDK_WAIT_FOR_RECEIPT=True
WDK_TX_TIMEOUT_SECONDS=120

# Logging
LOG_LEVEL=INFO
LOG_FILE=security_monitor.log
